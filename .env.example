## Docker Compose — copy this file to .env and fill in ALL required values.
## All passwords marked REQUIRED must be set; docker-compose will refuse to
## start if any are missing. Generate strong passwords with:
##   openssl rand -base64 32

# Database
POSTGRES_USER=innovacx_admin
# REQUIRED — admin/superuser password. Use a strong unique value.
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=complaints_db
APP_DB_USER=innovacx_app
# REQUIRED — runtime app role password. Use a strong unique value.
APP_DB_PASSWORD=devpassword

# Chatbot LLM
# Production model: Qwen2.5-1.5B-Instruct (benchmarked 2026-03-04, score 73.7 vs Falcon 66.3)
# Pre-downloaded on VM at /app/hf_cache/qwen2.5-1.5b-instruct (~3GB, no re-download needed)
# Local dev: leave CHATBOT_USE_MOCK=true to avoid loading the heavy model
CHATBOT_USE_MOCK=true
CHATBOT_MODEL_PATH=
# VM production values (set in .env on the VM — gitignored, never committed here):
#   CHATBOT_USE_MOCK=false
#   CHATBOT_MODEL_PATH=/app/hf_cache/qwen2.5-1.5b-instruct
# Quantization options for chatbot model: none | 8bit | 4bit
# Use 4bit/8bit only on CUDA GPUs; CPU setups will fall back to normal load.
CHATBOT_QUANTIZATION=none
# Keep responses shorter for better latency.
CHATBOT_MAX_NEW_TOKENS=96

# Orchestrator model dirs/files
# Defaults point to kept folders under:
# ai-models/MultiAgentPipeline/Orchestrator/agents/stepXX_*/model
SENTIMENT_MODEL_DIR=/app/agents/step04_sentimentanalysis/model
CLASSIFIER_MODEL_DIR=/app/agents/step03_classifier/model
# Optional overrides (leave empty to use files in CLASSIFIER_MODEL_DIR)
CLASSIFIER_MODEL_PATH=
CLASSIFIER_VECTORIZER_PATH=
FEATURE_LABELER_MODEL_PATH=/app/agents/step08_featureengineering/model
FEATURE_ENGINEERING_STATE_DIR=/app/agents/step08_featureengineering/model
PRIORITY_MODEL_DIR=/app/agents/step09_priority/model
DEPARTMENT_ROUTER_MODEL_PATH=/app/agents/step10_router/model
SUBJECT_GENERATOR_MODEL_PATH=/app/agents/step01_subjectgeneration/model
DEPARTMENT_ROUTING_THRESHOLD=0.7
DEPARTMENT_ROUTER_CALIBRATION_WEIGHT=0.12


# =============================================================================
# Required for the backup service. 
#
# BACKUP_PASSPHRASE:
#   AES-256 symmetric encryption passphrase for all backup files.
#   Use a strong random value in production, e.g.:
#     openssl rand -base64 32
#   There is NO default — docker-compose will refuse to start the backup
#   service unless this is explicitly set in .env.
#
# BACKUP_RETAIN_DAYS:
#   Number of days to keep backup files on the backup_data volume.
#   Default: 14 days (two weeks).
#
# =============================================================================

# REQUIRED — AES-256 backup encryption passphrase. Use a strong unique value.
# Generate with: openssl rand -base64 32
BACKUP_PASSPHRASE=devbackuppassphrase
BACKUP_RETAIN_DAYS=14

# =============================================================================
# Role separation passwords — REQUIRED.
# Each role must have its own strong unique password — do not reuse values.
# =============================================================================

# Password for innovacx_readonly (read-only reporting role)
READONLY_DB_PASSWORD=devpassword

# Password for innovacx_test (test environment role — never use in production)
TEST_DB_PASSWORD=devpassword

# Set true only for local dev — auto-creates/resets the 18 demo accounts on every startup.
# Never set true in production.
DEV_SEED_USERS=true

# =============================================================================
# Auth / Session
# =============================================================================

# REQUIRED — must be at least 32 random characters. Generate with:
#   openssl rand -hex 32
JWT_SECRET=supersecretkey
CSRF_SECRET=supersecretkey

# Hard session lifetime in seconds. Frontend idle-timeout (15 min) enforces
# inactivity logout independently. 28800 = 8 hours (one workday).
# Do not set below 900 in production.
JWT_TTL_SECONDS=28800

# Internal service-to-service API key.
INTERNAL_API_KEY=devinternalapikey
