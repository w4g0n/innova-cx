## Docker Compose defaults (copy to .env to customize)

# Database
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=complaints_db

# Hugging Face (for chatbot/LLM features)
HF_TOKEN=your_huggingface_token

# Sentiment service
# Set to "false" when you have a real model mounted
USE_MOCK_MODEL=true

# Path to your local model folder 
SENTIMENT_MODEL_PATH=
