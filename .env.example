## Docker Compose defaults (copy to .env to customize)

# Database
POSTGRES_USER=innovacx_admin
POSTGRES_PASSWORD=changeme123
POSTGRES_DB=complaints_db

# Hugging Face (for chatbot/LLM features)
HF_TOKEN=your_huggingface_token

# Chatbot LLM (mock by default; set local model path to enable heavy model)
CHATBOT_USE_MOCK=true
CHATBOT_MODEL_PATH=
# Quantization options for chatbot model: none | 8bit | 4bit
# Use 4bit/8bit only on CUDA GPUs; CPU setups will fall back to normal load.
CHATBOT_QUANTIZATION=none
# Keep responses shorter for better latency.
CHATBOT_MAX_NEW_TOKENS=96

# Orchestrator model dirs/files
# Defaults point to kept folders under:
# ai-models/MultiAgentPipeline/Orchestrator/models/
SENTIMENT_MODEL_DIR=/app/models/sentimentanalysis
CLASSIFIER_MODEL_DIR=/app/models/classifier
# Optional overrides (leave empty to use files in CLASSIFIER_MODEL_DIR)
CLASSIFIER_MODEL_PATH=
CLASSIFIER_VECTORIZER_PATH=
FEATURE_LABELER_MODEL_PATH=/app/models/featureengineering/feature_labeler
FEATURE_ENGINEERING_STATE_DIR=/app/models/featureengineering
