## .env.production.example
## Copy this file to .env on the GCP VM (/opt/innova-cx/.env).
## This file is committed to git as a reference. The actual .env is gitignored.
## All <placeholder> values must be replaced with real secrets before deployment.

# =============================================================================
# Database — PostgreSQL
# =============================================================================
POSTGRES_USER=innovacx_admin
POSTGRES_PASSWORD=<strong-password>
POSTGRES_DB=complaints_db

# Runtime role (least-privilege — used by backend, chatbot, orchestrator)
APP_DB_USER=innovacx_app
APP_DB_PASSWORD=<strong-password>

# Read-only role (reporting, future use)
READONLY_DB_PASSWORD=<strong-password>

# Test role (never used by production services)
TEST_DB_PASSWORD=<strong-password>

# =============================================================================
# Security / Auth
# =============================================================================
JWT_SECRET=<random-64-char-hex-min>
CSRF_SECRET=<random-64-char-hex-min>
INTERNAL_API_KEY=<random-32-char-min>
JWT_TTL_SECONDS=28800
MFA_TEMP_TTL_SECONDS=900
DISABLE_MFA=false

# =============================================================================
# Google OAuth (optional — leave blank to disable)
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# Frontend / CORS
# =============================================================================
ALLOWED_ORIGINS=https://innovacx.net,https://www.innovacx.net,https://staff.innovacx.net
VITE_API_BASE_URL=https://innovacx.net
VITE_GOOGLE_CLIENT_ID=

# =============================================================================
# System
# =============================================================================
SYSTEM_USER_EMAIL=customer1@innovacx.net
HF_TOKEN=<your_hf_token>
RESEND_API_KEY=<your_resend_api_key>

# =============================================================================
# Backup
# =============================================================================
BACKUP_PASSPHRASE=<strong-passphrase>
BACKUP_RETAIN_DAYS=14

# =============================================================================
# Chatbot
# =============================================================================
CHATBOT_LLM_PROVIDER=local
CHATBOT_MODEL_PATH=/app/models/<model-dir>
CHATBOT_MODEL_NAME=<hf-model-id>
CHATBOT_USE_MOCK=false
CHATBOT_AUTO_DOWNLOAD=false
CHATBOT_MAX_NEW_TOKENS=128
CHATBOT_QUANTIZATION=4bit

# =============================================================================
# ML Pipeline — Orchestrator
# =============================================================================

# Classifier
CLASSIFIER_MODEL_DIR=/app/agents/step03_classifier/model
CLASSIFIER_MODEL_PATH=
CLASSIFIER_VECTORIZER_PATH=

# Sentiment analysis
SENTIMENT_MODEL_DIR=/app/agents/step04_sentimentanalysis/model

# Feature engineering (zero-shot labeler)
FEATURE_LABELER_MODEL_PATH=/app/agents/step08_featureengineering/model
FEATURE_LABELER_AUTO_DOWNLOAD=false
FEATURE_LABELER_FORCE_CPU=false

# Department router
DEPARTMENT_ROUTER_MODEL_PATH=/app/agents/step10_router/model
DEPARTMENT_ROUTER_AUTO_DOWNLOAD=false
DEPARTMENT_ROUTER_FORCE_CPU=false
DEPARTMENT_ROUTER_CALIBRATION_WEIGHT=0.00

# Priority
PRIORITY_MODEL_DIR=/app/agents/step09_priority/model
PRIORITY_USE_MOCK=false

# Suggested resolution
SUGGESTED_RESOLUTION_MODEL_PATH=/app/agents/step02_suggestedresolution/model
SUGGESTED_RESOLUTION_MODEL_NAME=google/flan-t5-small
SUGGESTED_RESOLUTION_AUTO_DOWNLOAD=false
SUGGESTED_RESOLUTION_USE_MOCK=false
SUGGESTED_RESOLUTION_PIPELINE_ONLY=false

# Subject generator
SUBJECT_GENERATOR_MODEL_PATH=/app/agents/step01_subjectgeneration/model
SUBJECT_GENERATOR_MODEL_NAME=google/flan-t5-small
SUBJECT_GENERATOR_AUTO_DOWNLOAD=false

# Recurrence encoder
RECURRENCE_ENCODER_MODEL=/app/agents/step01_recurrence/model

# Transcriber (Whisper)
WHISPER_MODEL_NAME=base
WHISPER_MODEL_PATH=/app/model
